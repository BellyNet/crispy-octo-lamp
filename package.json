{
  "name": "lora-training",
  "version": "1.0.0",
  "description": "Scripts and tools for generating LoRA training data (images, captions, and tags).",
  "main": "milkmaid.js",
  "author": "TJ",
  "license": "MIT",
  "keywords": [
    "lora",
    "training",
    "stable-diffusion",
    "dataset",
    "nsfw"
  ],
  "scripts": {
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier . --write",
    "hoghaul": "node hoghaul/hoghaul.js",
    "milkmaid": "node milkmaid/milkmaid.js",
    "repair:stufferdb": "node milkmaid/repair-stufferdb-models.js",
    "report:repair-failures": "node milkmaid/report-repair-failures.js",
    "audit:slopvault": "node audit/audit-slopvault.js",
    "salvage:tail-video": "node audit/salvage-tail-videos.js --input",
    "salvage:tail-batch": "node audit/salvage-quarantine-tail-videos.js",
    "manifest:slopvault": "node audit/manifest-slopvault.js",
    "review:slopvault": "node audit/review-slopvault.js",
    "sync": "node scrapyard/sync.js",
    "sort:model-aliases": "node scrapyard/sortModelAliases.js",
    "purge-hashes": "node scrapyard/purgeModelHashes.js",
    "prune:model-hashes": "node scrapyard/pruneModelHashes.js",
    "remap:model": "node scrapyard/remapModelData.js",
    "backfill:sources": "node milkmaid/backfill-stufferdb-sources.js",
    "backfill:model-hashes": "node scrapyard/backfillModelHashes.js",
    "match:errored-video-visuals": "node scrapyard/matchErroredVideoVisuals.js",
    "backfill:quarantine-manifest": "node scrapyard/backfillQuarantineManifest.js",
    "validate:model-hashes": "node scrapyard/validateModelHashes.js",
    "validate:quarantine": "node scrapyard/validateQuarantineState.js",
    "dashboard": "node dashboard/server.js",
    "backfill:dates": "node milkmaid/backfill-exif-dates.js"
  },
  "dependencies": {
    "ansi-escapes": "^7.0.0",
    "canvas": "^3.1.2",
    "chalk": "^5.4.1",
    "dotenv": "^17.2.0",
    "express": "^5.2.1",
    "gif-frames": "^1.0.1",
    "image-hash": "^5.3.2",
    "imghash": "^0.0.9",
    "minimist": "^1.2.8",
    "p-limit": "^3.1.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "sharp": "^0.34.2",
    "strip-ansi": "^7.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@puppeteer/browsers": "^2.10.5",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.1",
    "globals": "^16.3.0",
    "install": "^0.13.0",
    "npm": "^11.4.2",
    "prettier": "^3.6.2",
    "puppeteer": "^24.12.0"
  }
}
