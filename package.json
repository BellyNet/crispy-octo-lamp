{
  "name": "lora-training",
  "version": "1.0.0",
  "description": "Scripts and tools for generating LoRA training data (images, captions, and tags).",
  "main": "scrapyard/run-scrape.js",
  "author": "TJ",
  "license": "MIT",
  "keywords": [
    "lora",
    "training",
    "stable-diffusion",
    "dataset",
    "nsfw"
  ],
  "scripts": {
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier . --write",
    "start": "node scrapyard/run-scrape.js",
    "scrape": "node scrapyard/run-scrape.js",
    "test:unified-scraper": "node scrapyard/smokeUnifiedScraper.js",
    "hoghaul": "node scrapyard/run-scrape.js",
    "hoghaul:all-coomerfans": "node scrapyard/run-source-batch.js --source=coomer --host-contains=coomerfans.com",
    "hoghaul:all-coomer": "node scrapyard/run-source-batch.js --source=coomer",
    "hoghaul:all-kemono": "node scrapyard/run-source-batch.js --source=kemono",
    "milkmaid": "node scrapyard/run-scrape.js",
    "scrape:interactive": "node scrapyard/run-scrape-interactive.js",
    "evict:nas-media": "node scrapyard/evictLocalNasBackedMedia.js",
    "evict:nas-media:apply": "node scrapyard/evictLocalNasBackedMedia.js --apply",
    "backfill:seen-media": "node milkmaid/backfill-seen-media-index.js",
    "repair:stufferdb": "node milkmaid/repair-stufferdb-models.js --scrape",
    "repair:scrape-only": "node milkmaid/repair-stufferdb-models.js --scrape-only",
    "update:stufferdb": "node scrapyard/run-stufferdb-batch.js",
    "update:all-models": "node scrapyard/run-all-source-updates.js",
    "report:repair-failures": "node milkmaid/report-repair-failures.js",
    "audit:missing-media": "node audit/audit-missing-media-refs.js",
    "audit:slopvault": "node audit/audit-slopvault.js",
    "repair": "node scrapyard/run-scrape.js repair",
    "repair:tail-decode": "node audit/run-session-repair.js",
    "salvage:tail-video": "node audit/salvage-tail-videos.js --input",
    "salvage:tail-batch": "node audit/salvage-quarantine-tail-videos.js",
    "manifest:slopvault": "node audit/manifest-slopvault.js",
    "review:slopvault": "node audit/review-slopvault.js",
    "manifest:slopvault-duplicates": "node audit/manifest-slopvault-duplicates.js",
    "review:slopvault-duplicates": "node audit/review-slopvault-duplicates.js",
    "review:slopvault-duplicates-express": "node audit/review-slopvault-duplicates-express.js",
    "sync": "node scrapyard/run-scrape.js sync",
    "restore:nas-mp4-hashes": "node scrapyard/restoreNasMp4Hashes.js",
    "sort:model-aliases": "node scrapyard/sortModelAliases.js",
    "purge-hashes": "node scrapyard/purgeModelHashes.js",
    "prune:model-hashes": "node scrapyard/pruneModelHashes.js",
    "remap:model": "node scrapyard/remapModelData.js",
    "backfill:sources": "node milkmaid/backfill-stufferdb-sources.js",
    "backfill:model-hashes": "node scrapyard/backfillModelHashes.js",
    "match:errored-video-visuals": "node scrapyard/matchErroredVideoVisuals.js",
    "backfill:quarantine-manifest": "node scrapyard/backfillQuarantineManifest.js",
    "validate:model-hashes": "node scrapyard/validateModelHashes.js",
    "validate:quarantine": "node scrapyard/validateQuarantineState.js",
    "dashboard": "node dashboard/server.js",
    "dashboard:prebuild": "node dashboard/build-meta-cache.js",
    "review:orientation": "node dashboard/orientation-review-server.js",
    "backfill:dates": "node milkmaid/backfill-exif-dates.js",
    "backfill:coomer": "node hoghaul/backfill-coomer-sources.js",
    "backfill:coomer-interactive": "node hoghaul/backfill-coomer-sources-interactive.js",
    "backfill:sources-interactive": "node hoghaul/backfill-sources-interactive.js",
    "sources:backfill-interactive": "node hoghaul/backfill-sources-interactive.js",
    "ingest:kemonodownloader": "node hoghaul/ingest-kemonodownloader.js",
    "probe:sources": "node hoghaul/batch-probe-sources.js",
    "backfill:exif": "node milkmaid/backfill-exif-dates.js",
    "cleanup:gif-derived-mp4s": "node scrapyard/removeGifDerivedMp4s.js",
    "cleanup:mirrored-mp4s": "node scrapyard/removeMirroredMp4s.js",
    "cleanup:flagged": "node scrapyard/cleanupFlaggedFiles.js",
    "cleanup:flagged:apply": "node scrapyard/cleanupFlaggedFiles.js --apply",
    "rebuild:nas-mp4-index": "node scrapyard/rebuildNasMp4Index.js",
    "prune:missing-media": "node scrapyard/pruneMissingMediaRefs.js"
  },
  "dependencies": {
    "ansi-escapes": "^7.0.0",
    "canvas": "^3.1.2",
    "chalk": "^5.4.1",
    "compression": "^1.8.1",
    "dotenv": "^17.2.0",
    "exifr": "^7.1.3",
    "express": "^5.2.1",
    "gif-frames": "^1.0.1",
    "image-hash": "^5.3.2",
    "imghash": "^0.0.9",
    "minimist": "^1.2.8",
    "p-limit": "^3.1.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "sharp": "^0.34.2",
    "strip-ansi": "^7.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@puppeteer/browsers": "^2.10.5",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.1",
    "globals": "^16.3.0",
    "install": "^0.13.0",
    "npm": "^11.4.2",
    "prettier": "^3.6.2",
    "puppeteer": "^24.12.0"
  }
}
